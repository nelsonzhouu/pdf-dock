# =============================================================================
# PDFDock — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in each value.
# Never commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for the global document counter on the homepage)
# -----------------------------------------------------------------------------
# Find these values in your Supabase project under Settings → API.
# The anon key is safe to expose publicly; it only has the permissions granted
# by your Row Level Security (RLS) policies.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# -----------------------------------------------------------------------------
# Stripe (required for the /donate page)
# -----------------------------------------------------------------------------
# Use test keys (sk_test_… / pk_test_…) during development.
# Switch to live keys (sk_live_… / pk_live_…) only in the production environment.
#
# IMPORTANT: STRIPE_SECRET_KEY must NEVER be prefixed with NEXT_PUBLIC_.
# It is used exclusively in the /api/create-checkout-session server route
# and is never sent to the browser.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
